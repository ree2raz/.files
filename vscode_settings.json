{
    "window.autoDetectColorScheme": true,
    "workbench.startupEditor": "none",
    "chat.disableAIFeatures": true,
    "editor.inlineSuggest.enabled": false,
    "editor.quickSuggestions": {
        "other": "off",
        "comments": "off",
        "strings": "off"
    },
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.hover.enabled": "off",
    "editor.codeLens": false,
    "workbench.tips.enabled": false,
    "workbench.enableExperiments": false,
    "extensions.ignoreRecommendations": true,
    "workbench.preferredDarkColorTheme": "Gruvbox Dark Hard",
    "gitlens.plusFeatures.enabled": false,
    "gitlens.showWhatsNewAfterUpgrades": false,
    "gitlens.ai.enabled": false,
    "gitlens.cloudIntegrations.enabled": false,
    "gitlens.integrations.enabled": false,
    "gitlens.telemetry.enabled": false,
    "chat.agent.enabled": false,
    "chat.mcp.access": "none",
    "chat.mcp.apps.enabled": false,
    "terminal.integrated.initialHint": false,
    "window.restoreWindows": "none",
    "window.openFoldersInNewWindow": "on",
    "editor.fontFamily": "'0xProto Nerd Font Mono'",
    "editor.fontSize": 13,
    "editor.lineHeight": 1.4,
    "editor.fontWeight": "500",

    "terminal.integrated.fontFamily": "'0xProto Nerd Font Mono'",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.lineHeight": 1.3,
    "terminal.integrated.fontWeight": "500",

    "debug.console.fontFamily": "'0xProto Nerd Font Mono'",
    "debug.console.fontSize": 13,
    "debug.console.lineHeight": 1.3,
    "debug.console.fontWeight": "500",

    "apc.font.family": "'0xProto Nerd Font Mono'",
    "apc.parts.font.family": {
        "sidebar": "'0xProto Nerd Font Mono'",
        "titlebar": "'0xProto Nerd Font Mono'",
        "activityBar": "'0xProto Nerd Font Mono'",
        "statusbar": "'0xProto Nerd Font Mono'"
    }
}
